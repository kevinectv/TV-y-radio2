# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# TMDB_API_KEY: Required for The Movie Database API calls.
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# MDBLIST_API_KEY: Required for MDBList API calls.
MDBLIST_API_KEY=YOUR_MDBLIST_API_KEY_HERE

# TRAKT_CLIENT_ID: Required for Trakt.tv API calls.
TRAKT_CLIENT_ID=YOUR_TRAKT_CLIENT_ID_HERE

# TRAKT_CLIENT_SECRET: Optional for Trakt.tv API calls.
TRAKT_CLIENT_SECRET=YOUR_TRAKT_CLIENT_SECRET_HERE
