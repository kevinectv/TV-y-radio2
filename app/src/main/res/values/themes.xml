<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Theme applied after splash screen is dismissed -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Guard against grey/white system layout flashes prior to first layout pass by initializing windows as solid dark -->
        <item name="android:windowBackground">#020202</item>
    </style>

    <!-- Seamless starting splash theme using official AndroidX SplashScreen API -->
    <style name="Theme.MyApplication.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>

</resources>
