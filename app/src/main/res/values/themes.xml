<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Theme applied after splash screen is dismissed -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Guard against grey/white system layout flashes prior to first layout pass by initializing windows as solid dark -->
        <item name="android:windowBackground">#020202</item>
    </style>

    <!-- Seamless cold-start splash theme -->
    <style name="Theme.MyApplication.Splash" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
